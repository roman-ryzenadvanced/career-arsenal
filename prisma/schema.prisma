// Prisma schema for Career Arsenal platform
// Multi-user — Telegram bot token is the login/identity.
// Each user has their own Profile, skill runs, jobs, applications, and Telegram bot.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  botToken      String   @unique // Telegram bot token — used as login
  botUsername   String?  // @username of the bot
  sessionToken  String?  // random session token for browser auth
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  profiles      Profile[]
  telegramBots  TelegramBot[]
}

model Profile {
  id            String   @id @default(cuid())
  userId        String   // Changed: now scoped to User, not standalone
  fullName      String?
  rawText       String   // raw extracted text from uploaded resume/LinkedIn export
  sourceKind    String   @default("resume")
  fileName      String?
  parsedJson    String?
  targetRole    String?
  targetContext String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  skillRuns     SkillRun[]
  uploads       UploadedFile[]
  jobPostings   JobPosting[]
  applications  Application[]
  telegramBots  TelegramBot[]

  @@index([userId])
}

model UploadedFile {
  id            String   @id @default(cuid())
  profileId     String
  fileName      String
  fileType      String
  fileSize      Int
  extractedText String
  createdAt     DateTime @default(now())

  profile       Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model SkillRun {
  id          String   @id @default(cuid())
  profileId   String
  skillId     String
  skillName   String
  input       String
  output      String
  modelUsed   String?
  createdAt   DateTime @default(now())

  profile     Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, skillId])
  @@index([createdAt])
}

model JobPosting {
  id            String   @id @default(cuid())
  profileId     String
  title         String
  company       String
  location      String?
  url           String?
  description   String?
  source        String   @default("web_search")
  salaryRange   String?
  jobType       String?
  remote        Boolean  @default(false)
  matchScore    Int?
  matchReason   String?
  status        String   @default("saved")
  appliedAt     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  profile       Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  applications  Application[]

  @@index([profileId, status])
  @@index([createdAt])
}

model Application {
  id                  String   @id @default(cuid())
  profileId           String
  jobId               String
  tailoredResume      String?
  coverLetter         String?
  coverLetterFormat   String?  @default("html")
  status              String   @default("draft")
  submittedAt         DateTime?
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  profile             Profile    @relation(fields: [profileId], references: [id], onDelete: Cascade)
  job                 JobPosting @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([profileId, status])
  @@index([jobId])
}

model TelegramBot {
  id              String   @id @default(cuid())
  userId          String   // Changed: now scoped to User
  profileId       String?  // Optional link to active profile
  botToken        String   @unique
  botUsername     String?
  chatId          String?
  isActive        Boolean  @default(true)
  defaultPersona  String   @default("recruiter")
  lastMessageAt   DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile         Profile? @relation(fields: [profileId], references: [id], onDelete: SetNull)

  @@index([userId])
}
