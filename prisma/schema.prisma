// Prisma schema for Career Arsenal platform
// Single user (no auth) — the platform stores one local profile + many skill runs

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Profile {
  id            String   @id @default(cuid())
  fullName      String?
  rawText       String   // raw extracted text from uploaded resume/LinkedIn export
  sourceKind    String   @default("resume") // "resume" | "linkedin"
  fileName      String?
  parsedJson    String?  // structured extraction (skills, experience, education) as JSON string
  targetRole    String?
  targetContext String?  // additional context user provides (target company, goals, etc.)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  skillRuns     SkillRun[]
  uploads       UploadedFile[]
}

model UploadedFile {
  id          String   @id @default(cuid())
  profileId   String
  fileName    String
  fileType    String   // mime type
  fileSize    Int
  extractedText String // extracted plain text from this file
  createdAt   DateTime @default(now())

  profile     Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model SkillRun {
  id          String   @id @default(cuid())
  profileId   String
  skillId     String   // e.g. "resume-architect", "cover-letter-craft"
  skillName   String
  input       String   // JSON string of inputs the user provided for this run
  output      String   // the LLM-generated output (markdown)
  modelUsed   String?
  createdAt   DateTime @default(now())

  profile     Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, skillId])
  @@index([createdAt])
}
